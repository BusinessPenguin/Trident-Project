# Core environment
ENV=dev
FEATURE_EQUITIES=false

# Supported crypto universe
CRYPTO_SYMBOLS=BTC-USD,ETH-USD,XRP-USD,SOL-USD,SUI-USD

# Storage
DATABASE_PATH=backend/var/trident.duckdb

# Data vendors
DATA_VENDOR=kraken
DISABLE_YF=1
NEWS_VENDOR=newsapi_ai
ONCHAIN_VENDOR=coingecko
TRIDENT_CALENDAR_COUNTRIES=US,JP

# AI provider defaults
AI_VENDOR=openai
AI_MODEL=gpt-5-mini
TRIDENT_USE_GPT=false
TRIDENT_GPT_MODEL=gpt-5.2

# Required public endpoints; no API keys needed
KRAKEN_BASE=https://api.kraken.com/0/public
COINGECKO_BASE=https://api.coingecko.com/api/v3

# Optional API keys; leave blank unless using that source
NEWSAPI_AI_KEY=
FRED_API_KEY=
FINNHUB_API_KEY=
OPENAI_API_KEY=

# Semi-simulated paper workflow defaults
PAPER_STARTING_EQUITY=10000
PAPER_SYMBOLS=BTC-USD,ETH-USD,XRP-USD,SOL-USD,SUI-USD
PAPER_FEE_BPS=5
PAPER_SLIPPAGE_BPS=8
PAPER_MAX_TRADES_PER_RUN=1
PAPER_MAX_OPEN_POSITIONS=5
PAPER_MAX_OPEN_POSITIONS_PER_SYMBOL=1
PAPER_MAX_RISK_PER_TRADE_PCT=0.01
PAPER_MAX_TOTAL_EXPOSURE_PCT=0.60
PAPER_REPLAY_INTERVAL=15m
PAPER_REPLAY_LOOKBACK_BARS=672
PAPER_ENTRY_MIN_SCORE=0.18
PAPER_ENTRY_MIN_EFFECTIVE_CONFIDENCE=0.40
PAPER_ENTRY_MIN_AGREEMENT=0.60
PAPER_ENTRY_MIN_MARGIN=0.06
PAPER_QUALITY_VETO_ENABLED=true
PAPER_GPT_LEARN_MAX_INFLUENCE=0.30
PAPER_INTEL_MODE=auto
PAPER_INTEL_BOOTSTRAP_TRADES=25
PAPER_INTEL_PROMOTION_TRADES=50
PAPER_PREDICTION_ENABLED=true
PAPER_PATTERN_ENABLED=true
PAPER_PREDICTION_WEIGHT_SOFT=0.15
PAPER_PATTERN_WEIGHT_SOFT=0.10
PAPER_PREDICTION_WEIGHT_HARD=0.20
PAPER_PATTERN_WEIGHT_HARD=0.10
PAPER_ALLOW_WEIGHTED_GATE_OVERRIDE=false
PAPER_LEARN_BOOTSTRAP_STOP_ONLY=true
PAPER_LEARN_APPLY_COOLDOWN_HOURS=24
PAPER_GPT_LEARN_MIN_TRADES=25
PAPER_NEWS_MIN_INTERVAL_MINUTES=60
PAPER_NEWS_MAX_PULLS_PER_DAY=10
PAPER_WEEKEND_RESCUE_GUARD=false
PAPER_WEEKEND_RESCUE_NOTIONAL_CAP=0.03
PAPER_ENTRY_RESCUE_ENABLED=true
PAPER_ENTRY_RESCUE_MAX_PER_RUN=1
PAPER_ENTRY_RESCUE_MIN_SCORE=0.05
PAPER_ENTRY_RESCUE_MIN_EFFECTIVE_CONFIDENCE=0.22
PAPER_ENTRY_RESCUE_MIN_AGREEMENT=0.55
PAPER_ENTRY_RESCUE_MIN_MARGIN=0.015
PAPER_ENTRY_RESCUE_NOTIONAL_CAP=0.06
PAPER_ENTRY_RESCUE_RISK_MULT=0.70
PAPER_ENTRY_RESCUE_STOP_MULT=1.30
PAPER_ENTRY_RESCUE_HOLD_MULT=0.90
PAPER_DB_SCHEMA_VERSION=5C.0
